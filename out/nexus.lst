 352+ 907F              .cp_go:
 353+ 907F                  ; Find max and min of prev_pupil[0..2]
 354+ 907F 3A DE EA         ld a, (prev_pupil)
 355+ 9082 47               ld b, a              ; min
 356+ 9083 4F               ld c, a              ; max
 357+ 9084 3A DF EA         ld a, (prev_pupil+1)
 358+ 9087 B8               cp b
 359+ 9088 30 01            jr nc, .cp1_not_min
 360+ 908A 47               ld b, a
