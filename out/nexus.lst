 438+ 86FC              ; Beeper 1-bit PCM sample playback
 439+ 86FC              ; Plays packed 1-bit data (8 samples/byte, MSB first) through
 440+ 86FC              ; the beeper at ~8kHz. CPU is locked during playback.
 441+ 86FC              ; ===============================================================
 442+ 86FC              play_hell_yeah:
 443+ 86FC CD 35 84         call ay_mute
 444+ 86FF 21 20 87         ld hl, hellyeah_data
 445+ 8702 11 36 06         ld de, HELLYEAH_BYTES
 446+ 8705 F3               di
 447+ 8706              .phy_byte:
 448+ 8706 46               ld b, (hl)
 449+ 8707 23               inc hl
 450+ 8708 0E 08            ld c, 8
 451+ 870A              .phy_bit:
 452+ 870A CB 10            rl b
 453+ 870C 9F               sbc a, a
 454+ 870D E6 10            and #10
 455+ 870F D3 FE            out (#fe), a
 456+ 8711 3E 17            ld a, 23
 457+ 8713              .phy_dly:
 458+ 8713 3D               dec a
 459+ 8714 20 FD            jr nz, .phy_dly
 460+ 8716 0D               dec c
 461+ 8717 20 F1            jr nz, .phy_bit
 462+ 8719 1B               dec de
 463+ 871A 7A               ld a, d
 464+ 871B B3               or e
 465+ 871C 20 E8            jr nz, .phy_byte
 466+ 871E FB               ei
 467+ 871F C9               ret
