  65+ E06D 32 D4 EA         ld (cursor_x), a
  66+ E070 32 D5 EA         ld (cursor_y), a
  67+ E073 32 CD EA         ld (key_held), a
  68+ E076 32 DC EA         ld (pupil_gauge), a
  69+ E079 32 DD EA         ld (flush_gauge), a
  70+ E07C 32 E5 EA         ld (pattern_flag), a
  71+ E07F 32 E6 EA         ld (blink_timer), a
