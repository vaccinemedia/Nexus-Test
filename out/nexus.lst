  28+ E02A 32 C3 80         ld (pr_col), a
  29+ E02D 21 0A C3         ld hl, str_of
  30+ E030 CD FE 80         call print_str
  31+ E033
  32+ E033                  ; Subject name on next line
  33+ E033 3A D0 EA         ld a, (level_num)
