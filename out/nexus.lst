   1+ 80C3              ; draw.asm — Direct screen output for Nexus
   2+ 80C3              ; Writes ROM font (8x8) directly to screen RAM. No plot routine needed.
   3+ 80C3              ;
   4+ 80C3              ; Screen address for char cell at column B (0-31), row D (0-23):
   5+ 80C3              ;   H = #40 | (D & #18)         ... selects third + base
   6+ 80C3              ;   L = ((D & 7) << 5) | B      ... selects char row within third + column
   7+ 80C3              ; Pixel rows within cell: consecutive values of H (just inc H).
   8+ 80C3
   9+ 80C3 00           pr_col: db 0
  10+ 80C4 00           pr_row: db 0
  11+ 80C5
  12+ 80C5              ; --- Print single character at (pr_col, pr_row) ---
  13+ 80C5              ; C = ASCII 32-127. Does NOT advance cursor. Preserves BC, DE, HL.
  14+ 80C5              print_char:
