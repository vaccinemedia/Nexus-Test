  31+ 80D5 11 00 3D         ld de, #3D00
  32+ 80D8 19               add hl, de
  33+ 80D9
  34+ 80D9                  ; Screen H byte
  35+ 80D9 3A C4 80         ld a, (pr_row)
  36+ 80DC E6 18            and #18
  37+ 80DE F6 40            or #40
  38+ 80E0 47               ld b, a
  39+ 80E1
  40+ 80E1                  ; Screen L byte
  41+ 80E1 3A C4 80         ld a, (pr_row)
  42+ 80E4 E6 07            and 7
  43+ 80E6 07               rlca
  44+ 80E7 07               rlca
  45+ 80E8 07               rlca
  46+ 80E9 07               rlca
  47+ 80EA 07               rlca
  48+ 80EB 4F               ld c, a
  49+ 80EC 3A C3 80         ld a, (pr_col)
