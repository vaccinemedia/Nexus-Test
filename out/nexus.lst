  16+ 80C6 D6 20            sub 32
  17+ 80C8 D8               ret c
  18+ 80C9 FE 60            cp 96
  19+ 80CB D0               ret nc
  20+ 80CC
  21+ 80CC C5               push bc
  22+ 80CD D5               push de
  23+ 80CE E5               push hl
  24+ 80CF
  25+ 80CF                  ; Font data = #3D00 + (char-32)*8
  26+ 80CF 6F               ld l, a
  27+ 80D0 26 00            ld h, 0
