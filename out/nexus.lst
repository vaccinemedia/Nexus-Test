  75+ 91D7              ; --- Populate active_subjects from archetype tables using RNG ---
  76+ 91D7              ; Called once at game start. For each of the 5 levels, flips a coin
  77+ 91D7              ; to pick human or android archetype, then copies SUBJ_SIZE bytes
  78+ 91D7              ; into active_subjects. Also randomizes portrait seed.
  79+ 91D7              init_active_subjects:
  80+ 91D7 DD 21 E7 EA      ld ix, active_subjects
  81+ 91DB 0E 00            ld c, 0             ; level index 0-4
  82+ 91DD              .ias_loop:
  83+ 91DD 79               ld a, c
  84+ 91DE FE 05            cp NUM_LEVELS
  85+ 91E0 D0               ret nc
  86+ 91E1
  87+ 91E1 C5               push bc
  88+ 91E2
  89+ 91E2                  ; Get RNG bit to decide human (0) or android (1)
  90+ 91E2 CD E8 90         call rng_tick
  91+ 91E5 E6 01            and 1
  92+ 91E7 28 08            jr z, .ias_human
  93+ 91E9
  94+ 91E9                  ; Android: source = subj_table_android + c * SUBJ_SIZE
  95+ 91E9 C1               pop bc
  96+ 91EA C5               push bc
  97+ 91EB 79               ld a, c
  98+ 91EC 21 31 91         ld hl, subj_table_android
  99+ 91EF 18 06            jr .ias_copy
 100+ 91F1
 101+ 91F1              .ias_human:
 102+ 91F1 C1               pop bc
 103+ 91F2 C5               push bc
 104+ 91F3 79               ld a, c
 105+ 91F4 21 FF 90         ld hl, subj_table_human
 106+ 91F7
 107+ 91F7              .ias_copy:
 108+ 91F7                  ; HL = table base, A = level index; compute HL += A * SUBJ_SIZE (10)
 109+ 91F7 B7               or a
 110+ 91F8 28 07            jr z, .ias_no_offset
 111+ 91FA 47               ld b, a
 112+ 91FB              .ias_mul:
 113+ 91FB 11 0A 00         ld de, SUBJ_SIZE
 114+ 91FE 19               add hl, de
 115+ 91FF 10 FA            djnz .ias_mul
 116+ 9201              .ias_no_offset:
 117+ 9201                  ; Copy SUBJ_SIZE bytes from (HL) to (IX)
 118+ 9201 06 0A            ld b, SUBJ_SIZE
 119+ 9203              .ias_cp_byte:
 120+ 9203 7E               ld a, (hl)
 121+ 9204 DD 77 00         ld (ix+0), a
 122+ 9207 23               inc hl
 123+ 9208 DD 23            inc ix
 124+ 920A 10 F7            djnz .ias_cp_byte
 125+ 920C
 126+ 920C                  ; Randomize portrait seed for this subject (overwrite bytes at offset 6-7)
 127+ 920C DD E5            push ix
 128+ 920E 11 FC FF         ld de, -SUBJ_SIZE + SUBJ_PORTRAIT
 129+ 9211 DD 19            add ix, de
 130+ 9213 CD E8 90         call rng_tick
 131+ 9216 DD 77 00         ld (ix+0), a
 132+ 9219 CD E8 90         call rng_tick
 133+ 921C DD 77 01         ld (ix+1), a
 134+ 921F DD E1            pop ix
 135+ 9221
 136+ 9221 C1               pop bc
 137+ 9222 0C               inc c
 138+ 9223 18 B8            jr .ias_loop
 139+ 9225
 140+ 9225              ; Look up active subject record: A = level (1-5), returns HL = pointer
 141+ 9225              get_subject_ptr:
 142+ 9225 3D               dec a
 143+ 9226 6F               ld l, a
 144+ 9227 26 00            ld h, 0
 145+ 9229 4D               ld c, l
 146+ 922A 44               ld b, h
 147+ 922B 29               add hl, hl
 148+ 922C 29               add hl, hl
 149+ 922D 09               add hl, bc
 150+ 922E 29               add hl, hl         ; HL = (level-1) * 10
 151+ 922F 01 E7 EA         ld bc, active_subjects
 152+ 9232 09               add hl, bc
 153+ 9233 C9               ret
 154+ 9234
 155+ 9234              ; A = level (1-5), returns A = penalty per question
 156+ 9234              get_penalty:
 157+ 9234 3D               dec a
 158+ 9235 21 63 91         ld hl, penalty_table
 159+ 9238 4F               ld c, a
 160+ 9239 06 00            ld b, 0
 161+ 923B 09               add hl, bc
 162+ 923C 7E               ld a, (hl)
 163+ 923D C9               ret
