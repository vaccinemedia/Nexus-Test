  44+ E048 32 C4 80         ld (pr_row), a
  45+ E04B CD FE 80         call print_str
  46+ E04E
  47+ E04E 3E 4B            ld a, INTRO_DELAY
  48+ E050 32 B2 E0         ld (intro_timer), a
  49+ E053 3E 01            ld a, 1
  50+ E055 32 CC EA         ld (screen_drawn), a
  51+ E058
  52+ E058              .li_wait:
  53+ E058 3A B2 E0         ld a, (intro_timer)
