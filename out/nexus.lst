   1+ C458              ; title.asm — Title screen with converted bitmap and attract mode
   2+ C458
   3+ C458              title_init:
   4+ C458 AF               xor a
   5+ C459 32 CC EA         ld (screen_drawn), a
   6+ C45C CD 52 84         call ay_init_title
   7+ C45F 21 00 00         ld hl, 0
   8+ C462 22 99 EB         ld (attract_timer), hl
   9+ C465 C9               ret
  10+ C466
  11+ C466              title_frame:
  12+ C466 3A CC EA         ld a, (screen_drawn)
  13+ C469 B7               or a
  14+ C46A C2 CF C4         jp nz, .tf_no_redraw
  15+ C46D
  16+ C46D                  ; Copy the pre-converted SCR bitmap directly to screen memory
  17+ C46D 21 FD C4         ld hl, title_scr_data
  18+ C470 CD C1 81         call copy_scr_to_screen
  19+ C473
  20+ C473                  ; Overlay title text on top of the bitmap
  21+ C473                  ; "NEXUS TEST" centred at row 3
  22+ C473 3E 0B            ld a, 11
  23+ C475 32 C3 80         ld (pr_col), a
  24+ C478 3E 03            ld a, 3
  25+ C47A 32 C4 80         ld (pr_row), a
  26+ C47D 21 D2 C2         ld hl, str_title
  27+ C480 CD FE 80         call print_str
  28+ C483
  29+ C483                  ; Brighten title row attrs (overwrite the bitmap attrs for these cells)
  30+ C483 16 03            ld d, 3
  31+ C485 06 0B            ld b, 11
  32+ C487 1E 0A            ld e, 10
  33+ C489 3E 45            ld a, ATTR_TITLE
  34+ C48B CD 77 81         call set_row_attrs
  35+ C48E
  36+ C48E                  ; "ANDROID DETECTION UNIT" at row 6
  37+ C48E 3E 05            ld a, 5
  38+ C490 32 C3 80         ld (pr_col), a
  39+ C493 3E 06            ld a, 6
  40+ C495 32 C4 80         ld (pr_row), a
  41+ C498 21 DD C2         ld hl, str_subtitle
  42+ C49B CD FE 80         call print_str
  43+ C49E
  44+ C49E 16 06            ld d, 6
  45+ C4A0 06 05            ld b, 5
  46+ C4A2 1E 16            ld e, 22
  47+ C4A4 3E 44            ld a, INK_GREEN + (INK_BLACK*8) + BRIGHT
  48+ C4A6 CD 77 81         call set_row_attrs
  49+ C4A9
  50+ C4A9                  ; "PRESS ANY KEY" at row 10
  51+ C4A9 3E 09            ld a, 9
  52+ C4AB 32 C3 80         ld (pr_col), a
  53+ C4AE 3E 0A            ld a, 10
  54+ C4B0 32 C4 80         ld (pr_row), a
  55+ C4B3 21 F4 C2         ld hl, str_press
  56+ C4B6 CD FE 80         call print_str
  57+ C4B9
  58+ C4B9 16 0A            ld d, 10
  59+ C4BB 06 09            ld b, 9
  60+ C4BD 1E 0E            ld e, 14
  61+ C4BF 3E 47            ld a, INK_WHITE + (INK_BLACK*8) + BRIGHT
  62+ C4C1 CD 77 81         call set_row_attrs
  63+ C4C4
  64+ C4C4 3E 01            ld a, 1
  65+ C4C6 32 CC EA         ld (screen_drawn), a
  66+ C4C9 21 00 00         ld hl, 0
  67+ C4CC 22 99 EB         ld (attract_timer), hl
  68+ C4CF
  69+ C4CF              .tf_no_redraw:
  70+ C4CF CD 9D 84         call ay_tick_music
  71+ C4D2
  72+ C4D2                  ; Attract mode timer
  73+ C4D2 2A 99 EB         ld hl, (attract_timer)
  74+ C4D5 23               inc hl
  75+ C4D6 22 99 EB         ld (attract_timer), hl
  76+ C4D9                  ; Check if 500 frames (10 seconds)
  77+ C4D9 7C               ld a, h
  78+ C4DA FE 01            cp 1
  79+ C4DC 38 13            jr c, .tf_check_key
  80+ C4DE 7D               ld a, l
  81+ C4DF FE F4            cp 244             ; 1*256+244 = 500
  82+ C4E1 38 0E            jr c, .tf_check_key
  83+ C4E3                  ; Switch to high score display
  84+ C4E3 AF               xor a
  85+ C4E4 32 CC EA         ld (screen_drawn), a
  86+ C4E7 3E 06            ld a, ST_HISCORE
  87+ C4E9 32 CB EA         ld (game_state), a
  88+ C4EC AF               xor a
  89+ C4ED 32 DC E7         ld (hiscore_entry_mode), a
  90+ C4F0 C9               ret
  91+ C4F1
  92+ C4F1              .tf_check_key:
  93+ C4F1 CD 0D 83         call read_any_key
  94+ C4F4 B7               or a
  95+ C4F5 C8               ret z
  96+ C4F6                  ; Start the game
  97+ C4F6 CD 35 84         call ay_mute
  98+ C4F9 CD A2 EA         call start_new_game
  99+ C4FC C9               ret
